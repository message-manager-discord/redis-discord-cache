{
  "compilerOptions": {
    "lib": ["es2024"],
    "target": "es2024",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "verbatimModuleSyntax": true,

    "strict": true,

    "rootDir": "src",
    "outDir": "dist",

    "declaration": true,
    "sourceMap": true,
    "resolveJsonModule": true,

    "types": ["node"]
  }
}
